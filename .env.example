# Token du bot Discord (Discord Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Clé API Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# Token GitHub avec droits repo (GitHub → Settings → Developer settings → Personal access tokens)
GITHUB_TOKEN=

# Repo cible au format : username/nom-du-repo
GITHUB_REPO=username/nom-du-repo

# IDs Discord autorisés à utiliser !dev (séparés par des virgules)
# Pour trouver ton ID : Discord → Paramètres → Avancé → Mode développeur → clic droit sur ton nom
AUTHORIZED_USER_IDS=123456789012345678,987654321098765432

# Dossier local où le repo sera cloné (chemin absolu ou relatif)
WORKDIR=./workspace
